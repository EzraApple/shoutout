# Copy to .env on the release machine.
# Keep .env private; it may contain machine-specific signing settings.

# Exact name from:
#   security find-identity -p codesigning -v | grep "Developer ID Application"
CODE_SIGN_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# Optional, used by the release preflight helper when printing setup commands.
APPLE_ID="you@example.com"
TEAM_ID="TEAMID"

# Keychain profile created with:
#   xcrun notarytool store-credentials notarytool-profile --apple-id "you@example.com" --team-id "TEAMID"
NOTARY_PROFILE="notarytool-profile"

# Optional local smoke test switch. Do not set this for public releases.
# SKIP_NOTARIZE=true

# Sparkle auto-updates. Generate the public key with:
#   make sparkle-public-key
SPARKLE_FEED_URL="https://shoutout.sh/appcast.xml"
SPARKLE_DOWNLOAD_URL_PREFIX="https://shoutout.sh/releases/"
SPARKLE_RELEASE_NOTES_URL_PREFIX="https://shoutout.sh/releases/"
SPARKLE_PUBLIC_ED_KEY="paste SUPublicEDKey here"

# Optional CI-only path for appcast signing. Prefer the local Keychain on your
# release machine. Never commit the private key.
# SPARKLE_PRIVATE_ED_KEY="base64-private-key"
