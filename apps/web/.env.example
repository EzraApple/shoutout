VITE_POSTHOG_KEY=phc_your_project_key
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Used by the Vercel /download redirect. This should point at the same
# website-only PostHog project as VITE_POSTHOG_KEY, so download clicks and
# server redirect events can be joined in funnels.
POSTHOG_PROJECT_API_KEY=phc_your_project_key
POSTHOG_HOST=https://us.i.posthog.com
SHOUTOUT_RELEASE_VERSION=0.1.0

# Optional. Set this if the DMG is hosted outside Vercel static files, such as
# GitHub Releases or Vercel Blob. Leave unset to use /releases/ShoutOut-0.1.0.dmg.
SHOUTOUT_DMG_URL=
