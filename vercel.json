{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm --prefix apps/web run build",
  "installCommand": "npm --prefix apps/web ci",
  "outputDirectory": "apps/web/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/download",
      "destination": "/api/download"
    }
  ]
}
